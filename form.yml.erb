  def class_supports_gpu_type?(klass, gpu_type)
    case gpu_type
    when "none"
      klass == "cpu"
    when "any"
      %w[gpu_a100_2 gpu_a100_h100_1 gpu_l40s_1 gpu_l40s_4 gpu_l40s_h200_2].include?(klass)
    when "a100"
      %w[gpu_a100_2 gpu_a100_h100_1].include?(klass)
    when "h100"
      klass == "gpu_a100_h100_1"
    when "l40s"
      %w[gpu_l40s_1 gpu_l40s_4 gpu_l40s_h200_2].include?(klass)
    when "h200nvl"
      klass == "gpu_l40s_h200_2"
    else
      false
    end
  end

  def class_supports_gpu_count?(klass, gpu_type, count)
    case gpu_type
    when "none"
      count == 0 && klass == "cpu"
    when "any"
      return true if count == 1 && %w[gpu_a100_2 gpu_a100_h100_1 gpu_l40s_1 gpu_l40s_4 gpu_l40s_h200_2].include?(klass)
      return true if count == 2 && %w[gpu_a100_2 gpu_l40s_4 gpu_l40s_h200_2].include?(klass)
      false
    when "a100"
      return true if count == 1 && %w[gpu_a100_2 gpu_a100_h100_1].include?(klass)
      return true if count == 2 && %w[gpu_a100_2].include?(klass)
      false
    when "h100"
      count == 1 && klass == "gpu_a100_h100_1"
    when "l40s"
      return true if count == 1 && %w[gpu_l40s_1 gpu_l40s_4 gpu_l40s_h200_2].include?(klass)
      return true if count == 2 && %w[gpu_l40s_4 gpu_l40s_h200_2].include?(klass)
      false
    when "h200nvl"
      return true if count == 1 && klass == "gpu_l40s_h200_2"
      return true if count == 2 && klass == "gpu_l40s_h200_2"
      false
    else
      false
    end
  end

