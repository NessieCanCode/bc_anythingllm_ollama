  modules: "singularityce/4.1.0"

  partition:
    widget: "select"
    label: "Slurm Partition (Queue)"
    help: |
      Select the partition (queue) the job should use.
    options:
<% ordered_partition_names.each do |display_name| %>
<% p = visible_partitions[display_name] %>
      - [ "<%= display_name %>", "<%= p[:slurm] %>",
          data-set-walltime: "<%= p[:walltime] %>",
          data-option-for-gpu-type-none: <%= class_supports_gpu_type?(p[:class], "none") %>,
          data-option-for-gpu-type-any: <%= class_supports_gpu_type?(p[:class], "any") %>,
          data-option-for-gpu-type-a100: <%= class_supports_gpu_type?(p[:class], "a100") %>,
          data-option-for-gpu-type-h100: <%= class_supports_gpu_type?(p[:class], "h100") %>,
          data-option-for-gpu-type-l40s: <%= class_supports_gpu_type?(p[:class], "l40s") %>,
          data-option-for-gpu-type-h200nvl: <%= class_supports_gpu_type?(p[:class], "h200nvl") %>
        ]
<% end %>

  gpu_type:
    widget: "select"
    label: "GPU Type"
    help: |
      Choose a GPU model. CPU partitions appear only for "No GPU / CPU only".
    options:
      - [ "No GPU / CPU only", "none" ]
      - [ "Any GPU", "any" ]
      - [ "A100", "a100" ]
      - [ "H100", "h100" ]
      - [ "L40S", "l40s" ]
      - [ "H200 NVL", "h200nvl" ]

