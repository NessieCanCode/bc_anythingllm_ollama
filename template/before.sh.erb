#!/bin/bash

# --- Helper Function for Timestamps ---
log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') [INFO] $1"
}

log "Cleaning up local LLM background processes..."
# Kill processes started by this specific user
pkill -u $USER -f "ollama serve"
pkill -u $USER -f "anythingllm"

# Clean up temporary Ollama sockets created in /tmp
rm -rf /tmp/ollama*

# Export the module environment
module purge
module load singularityce/4.1.0

# 1. Ports: Define the ports required for the relay and the app
export port=$(find_port)                  # The port OOD expects to connect to
export EXTERNAL_PORT=${port}              # resolvr listens here
export ALLM_INTERNAL_PORT=$(find_port)    # AnythingLLM runs here
export OLLAMA_PORT=$(find_port)           # Ollama runs here
export MCP_PORT=$(find_port)              # HPC MCP Server runs here

log "Assigned OOD Port: $port"
log "Assigned AnythingLLM Internal Port: $ALLM_INTERNAL_PORT"
log "Assigned Ollama API Port: $OLLAMA_PORT"
log "Assigned MCP Server Port: $MCP_PORT"

# 2. Define Image Paths
export OLLAMA_SIF="/opt/llm/ollama.sif"
export ALLM_SIF="/opt/llm/anythingllm.sif"
export RESOLVR_SIF="/opt/llm/resolvr.sif"
export OLLAMA_MODELS_DIR="/opt/llm/models"

# 3. Define user storage
export ALLM_USER_STORAGE="${HOME}/.anythingllm_storage"
mkdir -p "$ALLM_USER_STORAGE/prisma_client"

export OLLAMA_HOST="0.0.0.0:${OLLAMA_PORT}"

# 4. Pre-configure AnythingLLM to bind to the internal port
cat <<EOF > "$ALLM_USER_STORAGE/.env"
SERVER_PORT=$ALLM_INTERNAL_PORT
STORAGE_DIR=/app/server/storage
LLM_PROVIDER=ollama
OLLAMA_BASE_PATH=http://127.0.0.1:${OLLAMA_PORT}
OLLAMA_MODEL_PREF="<%= context.llm_model %>"
VECTOR_DB=lancedb
EMBEDDING_ENGINE=native
EOF

# 4.5 Create MCP server config for AnythingLLM (SSE Mode)
# mkdir -p "$ALLM_USER_STORAGE/plugins"
