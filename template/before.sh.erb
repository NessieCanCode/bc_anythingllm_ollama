# {
#   "mcpServers": {
#     "HPC": {
#       "type": "sse",
#       "url": "http://127.0.0.1:${MCP_PORT}/sse"
#     }
#   }
# }
# EOF

# 5. GPU Detection
if [ "<%= context.gpu_type %>" == "none" ]; then
  export HAS_GPU="false"
else
  export HAS_GPU="true"
fi
